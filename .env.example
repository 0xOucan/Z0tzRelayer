# Z0tz Relayer Configuration
#
# ONLY RELAYER_PRIVATE_KEY is required. Everything else has defaults.
# Run `npx hardhat run tasks/deploy-all.ts --network <chain>` to auto-fill
# chain-specific addresses.

# Relayer EOA private key (pays gas, gets reimbursed by paymaster)
RELAYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# RPC URLs — OPTIONAL (publicnode.com used by default)
# RPC_URL_11155111=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# RPC_URL_421614=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY
# RPC_URL_84532=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# EntryPoint (same on all chains)
ENTRYPOINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032

# Allowed chains — OPTIONAL (defaults to all)
# ALLOWED_CHAINS=31337,11155111,421614,84532

# --- Per-chain contract addresses (auto-filled by deploy-all.ts) ---

# Ethereum Sepolia (11155111)
# PAYMASTER_ADDRESS_11155111=
# FACTORY_ADDRESS_11155111=
# TOKEN_ADDRESS_11155111=
# BRIDGE_ADDRESS_11155111=

# Arbitrum Sepolia (421614)
# PAYMASTER_ADDRESS_421614=
# FACTORY_ADDRESS_421614=
# TOKEN_ADDRESS_421614=
# BRIDGE_ADDRESS_421614=

# Base Sepolia (84532)
# PAYMASTER_ADDRESS_84532=
# FACTORY_ADDRESS_84532=
# TOKEN_ADDRESS_84532=
# BRIDGE_ADDRESS_84532=

# Global fallbacks (used if chain-specific not set)
# PAYMASTER_ADDRESS=
# ACCOUNT_FACTORY_ADDRESS=

# Rate limiting
# MAX_OPS_PER_MINUTE=60
